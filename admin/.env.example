PORT=8080
HOST=localhost
URL=http://localhost:8080
LOG_LEVEL=info
APP_KEY=some_random_key
NODE_ENV=development
SESSION_DRIVER=cookie
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_DATABASE=nomad
DB_PASSWORD=password
DB_SSL=false
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional: point RoachNet at a local or external Ollama daemon instead of the managed container.
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional: point RoachNet at an OpenClaw runtime for health checks and future agent integration work.
OPENCLAW_BASE_URL=http://127.0.0.1:3001
# Storage path for NOMAD content (ZIM files, maps, etc.)
# For local macOS development, you can point this at the repo's admin/storage directory.
# On Windows dev, use an absolute path like: C:/nomad-storage
# On Linux production, use: /opt/project-nomad/storage
NOMAD_STORAGE_PATH=/opt/project-nomad/storage
